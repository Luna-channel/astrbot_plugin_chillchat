{
    "max_chars": {
        "description": "历史记录最大字符数",
        "type": "int",
        "hint": "历史记录超过此字符数时，从最旧的消息开始裁剪",
        "default": 8000
    },
    "apply_to": {
        "description": "生效范围",
        "type": "string",
        "options": ["private", "group", "all"],
        "hint": "private=仅私聊，group=仅群聊，all=全部",
        "default": "private"
    },
    "whitelist_users": {
        "description": "白名单用户",
        "type": "list",
        "hint": "白名单用户的ID列表，这些用户不会被裁剪历史记录",
        "default": []
    },
    "whitelist_groups": {
        "description": "白名单群聊",
        "type": "list",
        "hint": "白名单群聊的ID列表，这些群聊不会被裁剪历史记录",
        "default": []
    }
}
